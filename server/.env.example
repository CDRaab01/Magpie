# Local dev default matches docker-compose's host-published Postgres (127.0.0.1:5436 -> db:5432).
# Use 127.0.0.1, NOT localhost: the container publishes on IPv4 only, and `localhost` resolving
# to ::1 first makes every fresh connection eat a fallback delay (crippling under NullPool tests).
DATABASE_URL=postgresql+asyncpg://magpie:magpie@127.0.0.1:5436/magpie
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Suite SSO (the ONLY auth path — Magpie has no password login, CLAUDE.md locked decision) ---
# SUITE_JWKS_URL / SUITE_ISSUER are deliberately NOT set here — they're pinned in
# docker-compose.yml's `environment:` block instead (suite convention: Compose doesn't re-read
# changed env_file content on redeploy, so an env_file-only flag silently vanishing has bitten
# every sibling app at least once). Unset ⇒ POST /auth/suite 404s.

# --- Public deployment hardening ---
# Magpie is tailnet-only (Tailscale Serve, no Cloudflare tunnel) — these exist for parity with
# the suite's other apps but there's no reverse-proxy shape here to turn them on for.
# TRUST_PROXY=true
# HSTS_ENABLED=true
# Expose interactive API docs at /docs. Set false once this is reachable over the tailnet.
# DOCS_ENABLED=true

# Phase 1 adds SUITE_JWKS_URL/SUITE_ISSUER (SSO-only auth) and SECRET_KEY (local session
# tokens) — not needed yet for the Phase 0 health/version skeleton.
