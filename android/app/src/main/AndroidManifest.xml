<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- "Review your week" nudge (Tier W2b): an opt-in local reminder via AlarmManager.
         POST_NOTIFICATIONS is requested at runtime before the nudge can post; RECEIVE_BOOT_COMPLETED
         lets us re-arm the (non-persistent) alarm after a reboot. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- No android:usesCleartextTraffic, no network_security_config. Magpie is tailnet-only
         via Tailscale Serve, which terminates real HTTPS at the host's MagicDNS name — unlike
         Hawksnest's bare-Tailscale-IP case, there is no cleartext exception to justify here.
         See deploy/README.md and CLAUDE.md §8. -->

    <application
        android:name=".MagpieApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Magpie">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Magpie">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Static launcher shortcuts (long-press the app icon): Review / Add cash / Search.
                 Each is a magpie://shortcut/<target> VIEW intent MainActivity captures and threads
                 through the app lock + SSO gate before routing. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
            <!-- #34: ntfy alert deep links. Tapping a notification whose Click header is
                 magpie://<host> (bills/cashflow/accounts/review/home) opens the app on that
                 screen; MainActivity reads the host and MagpieNavHost routes it. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="magpie" />
            </intent-filter>
        </activity>

        <!-- #16: share exported CSVs via a content:// URI. grantUriPermissions lets the share
             target read the single file we hand it; no external-storage permission needed. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- AppAuth (suite SSO) themes its AuthorizationManagementActivity as AppCompat but
             leaves RedirectUriReceiverActivity to inherit the app theme, which isn't AppCompat
             -> it crashes on the redirect ("You need to use a Theme.AppCompat theme"). Force an
             AppCompat translucent theme on it — load-bearing, every suite app carries this. -->
        <activity
            android:name="net.openid.appauth.RedirectUriReceiverActivity"
            android:theme="@style/Theme.AppCompat.Translucent.NoTitleBar"
            tools:node="merge" />

        <!-- Home-screen money glance (net / safe-to-spend / to-review), reads the last-known snapshot. -->
        <receiver
            android:name=".widget.MagpieWidgetReceiver"
            android:exported="true"
            android:label="Magpie money">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/magpie_widget_info" />
        </receiver>

        <!-- "Review your week" nudge: an AlarmManager broadcast target that posts the reminder and
             re-arms next Sunday's alarm, plus a boot receiver to restore the alarm after a reboot. -->
        <receiver
            android:name=".util.nudge.ReviewNudgeReceiver"
            android:exported="false" />
        <receiver
            android:name=".util.nudge.NudgeBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
