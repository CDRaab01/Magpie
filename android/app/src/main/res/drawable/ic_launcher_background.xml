<?xml version="1.0" encoding="utf-8"?>
<!-- Suite-parity launcher background (2026-07-11): indigo -> teal -> green diagonal gradient,
     matching Spotter/Plate/Cookbook's glyph-on-colored-circle language. The magpie foreground is
     now a white silhouette, so it reads cleanly on the gradient (unlike the old colored bird,
     which needed a light ground). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:offset="0.0" android:color="#FF5B2BE0" />
                <item android:offset="0.5" android:color="#FF0F766E" />
                <item android:offset="1.0" android:color="#FF047857" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
